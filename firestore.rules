rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return isAuth() && request.auth.uid == resource.data.ownerId;
    }

    // An album is readable when it is public, the requester owns it, or the
    // requester's uid is in the memberIds array (member-based access, replaces
    // the old group-based check).
    function canReadAlbum(album) {
      return album.data.visibility == 'public'
        || (isAuth() && album.data.ownerId == request.auth.uid)
        || (isAuth()
            && album.data.memberIds != null
            && request.auth.uid in album.data.memberIds);
    }

    // ── Dev environment ──────────────────────────────────────────────────────

    match /users-dev/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /albums-dev/{albumId} {
      allow read: if canReadAlbum(resource);
      allow create: if isAuth();
      allow update: if isOwner(resource);
      allow delete: if isOwner(resource) && resource.data.mediaCount == 0;

      match /media/{mediaId} {
        allow read: if canReadAlbum(
          get(/databases/$(database)/documents/albums-dev/$(albumId)));
        allow create: if isAuth();
        allow update: if isAuth() && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid ==
            get(/databases/$(database)/documents/albums-dev/$(albumId)).data.ownerId
        );
        allow delete: if isAuth() && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid ==
            get(/databases/$(database)/documents/albums-dev/$(albumId)).data.ownerId
        );
      }
    }

    // ── Prod environment ─────────────────────────────────────────────────────

    match /users-prod/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /albums-prod/{albumId} {
      allow read: if canReadAlbum(resource);
      allow create: if isAuth();
      allow update: if isOwner(resource);
      allow delete: if isOwner(resource) && resource.data.mediaCount == 0;

      match /media/{mediaId} {
        allow read: if canReadAlbum(
          get(/databases/$(database)/documents/albums-prod/$(albumId)));
        allow create: if isAuth();
        allow update: if isAuth() && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid ==
            get(/databases/$(database)/documents/albums-prod/$(albumId)).data.ownerId
        );
        allow delete: if isAuth() && (
          request.auth.uid == resource.data.uploaderId ||
          request.auth.uid ==
            get(/databases/$(database)/documents/albums-prod/$(albumId)).data.ownerId
        );
      }
    }
  }
}
